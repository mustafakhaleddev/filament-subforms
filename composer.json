{
    "name": "wezlo/filament-subforms",
    "description": "Embed another Filament Resource's form inside a parent form as a sub-form.",
    "keywords": ["laravel", "filament", "forms", "subform", "nested"],
    "license": "MIT",
    "version": "1.0.0",
    "type": "library",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Wezlo\\FilamentSubForms\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wezlo\\FilamentSubForms\\FilamentSubFormsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
